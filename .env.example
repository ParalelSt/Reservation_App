# ===========================================
# VERCEL / PRODUCTION ENVIRONMENT
# Copy this to your Vercel project environment variables
# ===========================================

# PostgreSQL (use your hosted Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/reservation_db?sslmode=require

# Auth0
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=https://your-domain.vercel.app

# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Admin access — comma-separated list of admin emails
ADMIN_EMAILS=admin@example.com
